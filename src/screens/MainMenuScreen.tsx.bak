              cursor: item.disabled ? 'default' : 'pointer',
              textAlign: 'center',
              display: 'flex',
              flexDirection: 'column',
              alignItems: 'center',
              justifyContent: 'center',
              gap: '5px',
              boxShadow: item.primary
                ? '0 0 32px rgba(167,139,250,0.08), inset 0 1px 0 rgba(167,139,250,0.1)'
