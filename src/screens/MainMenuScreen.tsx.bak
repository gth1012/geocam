          marginBottom: '14px',
          textTransform: 'uppercase',
        }}>
          K-pop Photocard Authentication
        </p>
        <h1 style={{
          fontSize: '2.6rem',
          fontWeight: '200',
          letterSpacing: '0.2em',
          color: '#a78bfa',
          margin: '0',
          lineHeight: 1,
