// Auth UX 리팩 v2.0 (2026-06-22)
// UI/UX 리팩 v3.3 (2026-06-28) — 정품 인증하기 → certSelect 연결

const MainMenuScreen = ({
  safeGoHome,
  safeGoCamera,
  safeGoScan,
